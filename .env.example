POSTGRES_USER=resume_user
POSTGRES_PASSWORD=resume_pass_local
POSTGRES_DB=resume_analyze

REDIS_PASSWORD=change_me_redis

# Генерировать: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_64_chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_64_chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
APP_HOST=localhost

# Опционально: Personal Access Token для увеличения rate limit (5000 req/h вместо 60)
# Создать: https://github.com/settings/tokens
GITHUB_TOKEN=

OPENAI_API_KEY=
# или для Anthropic Claude:
# ANTHROPIC_API_KEY=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM="Resume Analyze <your@email.com>"
